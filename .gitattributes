# =========================================
# Auto detect text files
# =========================================

* text=auto


# =========================================
# C# / .NET
# =========================================

*.cs         text diff=csharp
*.csproj     text
*.sln        text eol=crlf


# =========================================
# Config / Structured files
# =========================================

*.json       text
*.xml        text
*.yml        text eol=lf
*.yaml       text eol=lf


# =========================================
# Scripts
# =========================================

*.sh         text eol=lf
*.ps1        text eol=crlf
*.cmd        text eol=crlf
*.bat        text eol=crlf


# =========================================
# Markdown / Documentation
# =========================================

*.md         text


# =========================================
# Binary files
# =========================================

*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.zip        binary
*.dll        binary